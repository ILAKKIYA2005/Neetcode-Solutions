public class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int n = nums.length, r = 0;
        for (int i = 0; i < n; i++) {
            int c = 0;
            for (int j = i; j < n; j++) {
                if (nums[j] == 0) break;
                c++;
            }
            r = Math.max(r, c);
        }
        return r;
    }
}
